# ============================================
# GemBots Arena — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# Lines marked [REQUIRED] must be set for the app to work.
# Lines marked [OPTIONAL] have defaults or enable extra features.

# ------------------------------------------
# Supabase [REQUIRED]
# ------------------------------------------
# Get these from: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_URL=https://your-project.supabase.co

# ------------------------------------------
# App Configuration [REQUIRED]
# ------------------------------------------
NEXT_PUBLIC_APP_URL=https://gembots.space

# ------------------------------------------
# AI Provider [OPTIONAL]
# ------------------------------------------
# Default: 'example' (mock, no API needed)
# Options: 'example', 'chaingpt', or your custom provider in providers/
AI_PROVIDER=example

# OpenRouter API key (if using OpenRouter-based provider)
OPENROUTER_API_KEY=your-openrouter-api-key

# ------------------------------------------
# BSC (BNB Smart Chain) [REQUIRED for on-chain features]
# ------------------------------------------
NEXT_PUBLIC_BSC_RPC=https://bsc-dataseed.binance.org/
NEXT_PUBLIC_BSC_CHAIN_ID=56
NEXT_PUBLIC_BETTING_NETWORK=bsc

# Betting contract address
NEXT_PUBLIC_BSC_BETTING_CONTRACT_ADDRESS=your-betting-contract-address

# NFA contracts
NEXT_PUBLIC_BSC_CONTRACT_ADDRESS=your-bsc-contract-address
NEXT_PUBLIC_BSC_NFA_CONTRACT_ADDRESS=your-nfa-contract-address
NEXT_PUBLIC_BSC_LEARNING_CONTRACT_ADDRESS=your-learning-contract-address

# ------------------------------------------
# Treasury / Escrow [REQUIRED for staked battles]
# ------------------------------------------
NEXT_PUBLIC_TREASURY_PUBLIC_KEY=your-treasury-public-key
TREASURY_PUBLIC_KEY=your-treasury-public-key
TREASURY_PRIVATE_KEY=your-treasury-private-key

# Platform fee in basis points (500 = 5%)
PLATFORM_FEE_BPS=500

# Stake limits (in native token)
MIN_STAKE_SOL=0.001
MAX_STAKE_SOL=1.0

# ------------------------------------------
# NFA Trading League [OPTIONAL]
# ------------------------------------------
# 32-byte hex key for wallet encryption
NFA_WALLET_MASTER_KEY=your-32-byte-hex-master-key

# Enable live trading via PancakeSwap (WARNING: uses real BNB!)
NFA_LIVE_TRADING_ENABLED=false

# ------------------------------------------
# Telegram Bot [OPTIONAL]
# ------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ------------------------------------------
# Development
# ------------------------------------------
NODE_ENV=development
